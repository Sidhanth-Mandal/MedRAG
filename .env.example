# ============================================================
#  Agentic RAG — Medical Q&A  |  .env.example
#  Copy this file to .env and fill in your actual values.
#  Never commit .env to version control.
# ============================================================

# ── NCBI / PubMed ──────────────────────────────────────────
ENTREZ_EMAIL=your-email@example.com          # Required by NCBI for Entrez API

# ── Qdrant Cloud ───────────────────────────────────────────
QDRANT_URL=https://<your-cluster>.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=medical_rag

# ── Cloudflare Workers AI (Embeddings) ─────────────────────
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token

# ── Cohere (Reranking) ─────────────────────────────────────
COHERE_API_KEY=your_cohere_api_key_here

# ── Groq (LLM — 4 keys for round-robin rotation) ──────────
GROQ_API_KEY_1=your_groq_api_key_1
GROQ_API_KEY_2=your_groq_api_key_2
GROQ_API_KEY_3=your_groq_api_key_3
GROQ_API_KEY_4=your_groq_api_key_4

# ── Supabase (Chat History / Checkpointing) ────────────────
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project>.supabase.co:5432/postgres

# ── Authentication ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30
